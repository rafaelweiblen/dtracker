# Turso (SQLite edge DB)
# Para dev local, deixe em branco — usa file:./local.db automaticamente
# Para produção, crie um banco em https://turso.tech e preencha abaixo:
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Auth.js (Google OAuth)
# Crie credenciais em https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Auth.js secret (gere com: openssl rand -base64 32)
AUTH_SECRET=your-auth-secret
