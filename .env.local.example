# URL pública do site (opcional; melhora Open Graph e sitemap em produção)
# Ex.: https://dtracker-six.vercel.app
# NEXT_PUBLIC_SITE_URL=

# Turso (SQLite edge DB)
# Para dev local, deixe em branco — usa file:./local.db automaticamente
# Para produção, crie um banco em https://turso.tech e preencha abaixo:
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Auth.js (Google OAuth) — Auth.js v5 usa preferencialmente AUTH_GOOGLE_*
# (GOOGLE_CLIENT_* também funciona neste projeto como alias)
# Crie credenciais em https://console.cloud.google.com → APIs & Services → Credentials
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Auth.js secret (gere com: openssl rand -base64 32)
AUTH_SECRET=your-auth-secret

# ─── Migrações em produção ───
# O .env.local acima normalmente NÃO tem TURSO_* → pnpm db:migrate usa local.db.
# Para aplicar migrações na Turso de PROD (antes de vercel --prod):
#   pnpm db:env:prod && pnpm db:migrate:prod
# Ver app/.specs/codebase/INTEGRATIONS.md

# Porta do `pnpm dev`: ajusta em package.json no script "dev" (flag -p).

# ─── Apenas desenvolvimento local (nunca em produção) ───
# Salta login Google: exige NODE_ENV=development + `pnpm dev`.
# Cria o utilizador na BD antes: `pnpm db:seed:dev`
# AUTH_BYPASS=true
# ID do utilizador em `users` (default abaixo se omitires)
# AUTH_BYPASS_USER_ID=00000000-0000-0000-0000-000000000001
